# Virtual environments
**/venv/**
**/.venv/**

# Frontend
frontend/node_modules/**
frontend/package-lock.json

# Python bytecode
**/*.pyc
**/*.pyo
**/*.pyd
**/*.pyw
**/*.pyz
**/*.pywz
**/*.pyzw
**/__pycache__/

# Environment files
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Storage (runtime data)
**/storage/messages/**
**/storage/profiles/**
**/storage/sessions/**
**/storage/test_drives/**

# IDE
**/.idea/**
**/.vscode/**
**/.DS_Store

# Test & coverage artifacts
**/.coverage
**/.pytest_cache/
**/.ruff_cache/
**/.mypy_cache/
**/htmlcov/
**/coverage.xml
**/test-results.xml

